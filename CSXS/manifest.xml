<?xml version="1.0" encoding="UTF-8"?>
<!--
  Kinea — CEP extension manifest (CSXS 9 / CEP 9).
  Targets After Effects 2020 (17.0) and later, Windows + macOS.
  CSXS 9.0 is a MINIMUM, so this also loads on AE 2021/2022+ (CSXS 10/11/12).
  Node is enabled in the panel context so the bridge can spawn CLI agents.
-->
<ExtensionManifest Version="9.0"
                   ExtensionBundleId="com.kinea.extension"
                   ExtensionBundleVersion="0.1.0"
                   ExtensionBundleName="Kinea"
                   xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">

  <ExtensionList>
    <Extension Id="com.kinea.panel" Version="0.1.0"/>
  </ExtensionList>

  <ExecutionEnvironment>
    <HostList>
      <!-- AEFT 17.0 = After Effects 2020; open upper bound for forward compat -->
      <Host Name="AEFT" Version="[17.0,99.9]"/>
    </HostList>
    <LocaleList>
      <Locale Code="All"/>
    </LocaleList>
    <RequiredRuntimeList>
      <RequiredRuntime Name="CSXS" Version="9.0"/>
    </RequiredRuntimeList>
  </ExecutionEnvironment>

  <DispatchInfoList>
    <Extension Id="com.kinea.panel">
      <DispatchInfo>
        <Resources>
          <MainPath>./client/index.html</MainPath>
          <ScriptPath>./host/index.jsx</ScriptPath>
          <CEFCommandLine>
            <!-- Enable the Node.js context for the bridge (Golden rule: BYO CLI) -->
            <Parameter>--enable-nodejs</Parameter>
            <Parameter>--mixed-context</Parameter>
          </CEFCommandLine>
        </Resources>
        <Lifecycle>
          <AutoVisible>true</AutoVisible>
        </Lifecycle>
        <UI>
          <Type>Panel</Type>
          <Menu>Kinea</Menu>
          <Geometry>
            <Size>
              <Height>520</Height>
              <Width>360</Width>
            </Size>
            <MinSize>
              <Height>320</Height>
              <Width>260</Width>
            </MinSize>
          </Geometry>
        </UI>
      </DispatchInfo>
    </Extension>
  </DispatchInfoList>
</ExtensionManifest>
